# Supabase
# Copy this file to .env and replace these placeholders with real values.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_service_or_anon_key

# Vector Store
VECTOR_STORE_BACKEND=supabase

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
SUMMARY_THRESHOLD=10
LOW_CONFIDENCE_THRESHOLD=0.25

# LLM Provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-3.5-turbo
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama3-8b-8192

# App Config
YOUR_SITE_URL=http://localhost:8501
YOUR_SITE_NAME=DocMind
