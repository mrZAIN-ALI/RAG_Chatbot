# Supabase
# Supabase project URL used by FastAPI, Streamlit, and document storage.
SUPABASE_URL=https://your-project.supabase.co

# Supabase API key. Use a service role key for trusted backend deployments.
SUPABASE_API_KEY=your_supabase_service_or_anon_key

# Vector Store
# Supported values: supabase, faiss, chroma.
VECTOR_STORE_BACKEND=supabase

# Retrieval
# Number of candidate chunks to retrieve before reranking.
RETRIEVAL_TOP_K=20

# Number of reranked chunks to send into answer generation.
RERANK_TOP_N=5

# Conversation length threshold before summary maintenance runs.
SUMMARY_THRESHOLD=10

# Confidence score threshold for low-confidence logging and warnings.
LOW_CONFIDENCE_THRESHOLD=0.25

# LLM Provider
# Supported values: gemini, openai, groq.
LLM_PROVIDER=gemini

# Google Gemini credentials and model.
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI credentials and model.
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4

# Groq credentials and model.
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama3-8b-8192

# App Config
# Public site metadata used by local app flows and examples.
YOUR_SITE_URL=http://localhost:3000
YOUR_SITE_NAME=DocMind

# Public FastAPI base URL used by the Next.js frontend.
# Locally this points to FastAPI; in Vercel set it to your Railway URL.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# API base used by local integration tests and Makefile full-stack checks.
DOCMIND_API_BASE=http://127.0.0.1:8000
